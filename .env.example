# Open-Meteo MCP Server Environment Configuration
# Copy this file to .env and fill in your values

# API Configuration
# Get your API key from https://open-meteo.com/en/pricing (optional, for commercial use)
OPEN_METEO_API_KEY=

# Request timeout in seconds (default: 30.0)
OPEN_METEO_TIMEOUT=30.0

# Default timezone for responses (default: GMT)
# Examples: Europe/Berlin, America/New_York, Asia/Tokyo
OPEN_METEO_TIMEZONE=GMT

# Rate limiting delay in seconds between requests (default: 0.1)
# Increase if you encounter rate limit errors
OPEN_METEO_RATE_LIMIT=0.1
