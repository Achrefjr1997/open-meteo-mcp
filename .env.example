# Open-Meteo MCP Server Environment Configuration
# Copy this file to .env and fill in your values

# ==================== API Configuration ====================
# Get your API key from https://open-meteo.com/en/pricing (optional, for commercial use)
OPEN_METEO_API_KEY=

# Request timeout in seconds (default: 30.0)
OPEN_METEO_TIMEOUT=30.0

# Default timezone for responses (default: GMT)
# Examples: Europe/Berlin, America/New_York, Asia/Tokyo
OPEN_METEO_TIMEZONE=GMT

# Rate limiting delay in seconds between requests (default: 0.1)
# Increase if you encounter rate limit errors
OPEN_METEO_RATE_LIMIT=0.1

# ==================== API Base URLs ====================
# These are the official Open-Meteo API endpoints
# Do not change unless using a proxy or custom setup

# Main Weather API (forecasts, current weather, historical)
OPEN_METEO_API_URL=https://api.open-meteo.com

# Air Quality API (PM, gases, AQI, pollen)
OPEN_METEO_AIR_QUALITY_API_URL=https://air-quality-api.open-meteo.com

# Marine Weather API (waves, swells, marine conditions)
OPEN_METEO_MARINE_API_URL=https://marine-api.open-meteo.com

# Historical Archive API (1940-present reanalysis data)
OPEN_METEO_ARCHIVE_API_URL=https://archive-api.open-meteo.com

# Seasonal Forecast API (long-range forecasts)
OPEN_METEO_SEASONAL_API_URL=https://seasonal-api.open-meteo.com

# Ensemble Forecast API (multi-model ensembles)
OPEN_METEO_ENSEMBLE_API_URL=https://ensemble-api.open-meteo.com

# Geocoding API (location search)
OPEN_METEO_GEOCODING_API_URL=https://geocoding-api.open-meteo.com

# Flood API (flood forecasts)
OPEN_METEO_FLOOD_API_URL=https://flood-api.open-meteo.com

# Climate API (climate normals, trends)
OPEN_METEO_CLIMATE_API_URL=https://climate-api.open-meteo.com
